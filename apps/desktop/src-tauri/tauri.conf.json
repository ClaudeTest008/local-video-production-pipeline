{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LVPP Studio",
  "version": "1.0.0",
  "identifier": "dev.lvpp.studio",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix ../.. run dev:web",
    "frontendDist": "../../web/out",
    "beforeBuildCommand": "npm --prefix ../.. run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "LVPP Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8321 http://localhost:8321 http://127.0.0.1:8188; img-src 'self' data: http://127.0.0.1:8188; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/lvpp-backend"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "shortDescription": "Local-first AI Creator OS",
    "longDescription": "LVPP Studio — a local-first AI production studio. You direct; a crew of AI agents researches, writes, storyboards, renders, and optimizes your content."
  }
}
